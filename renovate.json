{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":automergeMinor",
    ":automergePatch",
    "schedule:weekends"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/.+\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Group database updates together",
      "groupName": "databases",
      "automerge": false,
      "matchPackageNames": [
        "/postgres/",
        "/pgautoupgrade/",
        "/mariadb/",
        "/redis/"
      ]
    },
    {
      "description": "Group monitoring stack updates",
      "groupName": "monitoring",
      "matchPackageNames": [
        "/prometheus/",
        "/grafana/",
        "/promtail/"
      ]
    },
    {
      "description": "Group security updates",
      "groupName": "security",
      "automerge": false,
      "matchPackageNames": [
        "/crowdsec/",
        "/authentik/"
      ]
    },
    {
      "description": "Pin digest for critical services",
      "matchPackageNames": ["vaultwarden/server"],
      "automerge": false
    },
    {
      "description": "Don't update mysql",
      "matchPackageNames": ["/mysql/"],
      "enabled": false
    }
  ]
}
